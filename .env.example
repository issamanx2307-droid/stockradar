# ── Django ──────────────────────────────────────────────────────────────────
# ⚠️ ต้องใส่ค่าจริงก่อน deploy — ห้ามใช้ค่า default ใน production
DJANGO_SECRET_KEY=your-super-secret-key-change-this
# ⚠️ ห้าม set DEBUG=True ใน production (stack trace โผล่ต่อ public, CORS เปิดทุก origin)
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
# Local SQLite (default — ไม่ต้องตั้ง)
# DATABASE_URL=sqlite:///db.sqlite3

# Production PostgreSQL (Render จะ inject ให้อัตโนมัติ)
# DATABASE_URL=postgresql://user:password@host:5432/stockradar

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local: ไม่ต้องตั้ง (ใช้ InMemory)
# Production Render Redis:
# REDIS_URL=redis://red-xxxx:6379

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production frontend URL
# CORS_ORIGINS=https://stockradar-ui.onrender.com

# ── Frontend API URL (Vite) ──────────────────────────────────────────────────
# VITE_API_URL=https://stockradar-api.onrender.com/api
